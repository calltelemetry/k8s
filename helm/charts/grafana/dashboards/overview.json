{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "Service Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "PostgreSQL",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "pg_up", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } },
      "links": [{ "title": "PostgreSQL", "url": "/d/ct-postgresql/postgresql" }]
    },
    {
      "title": "NATS",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "gnatsd_varz_current_connections > 0 or vector(0)", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 3, "y": 1 },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "range", "options": { "from": 1, "to": 999999, "result": { "text": "UP", "color": "green" } } }, { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } }] } },
      "links": [{ "title": "NATS", "url": "/d/ct-nats/nats-jetstream" }]
    },
    {
      "title": "S3 Storage",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "minio_cluster_nodes_online_total", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 6, "y": 1 },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "range", "options": { "from": 1, "to": 999999, "result": { "text": "UP", "color": "green" } } }, { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } }] } },
      "links": [{ "title": "S3 Storage", "url": "/d/ct-minio/minio-object-storage" }]
    },
    {
      "title": "Caddy",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "caddy_http_requests_in_flight >= 0 or vector(0)", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 9, "y": 1 },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "range", "options": { "from": 0, "to": 999999, "result": { "text": "UP", "color": "green" } } }] } },
      "links": [{ "title": "Caddy", "url": "/d/ct-caddy/caddy-gateway" }]
    },
    {
      "title": "JTAPI CTI Pool",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "jtapi_cti_pool_operational", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } },
      "links": [{ "title": "JTAPI Sidecar", "url": "/d/ct-jtapi-sidecar/jtapi-sidecar" }]
    },
    {
      "title": "JTAPI Streaming",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "jtapi_streaming_available", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 15, "y": 1 },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "STUB", "color": "yellow" }, "1": { "text": "REAL", "color": "green" } } }] } }
    },
    {
      "title": "OTEL Collector",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "sum(rate(otelcol_receiver_accepted_spans[1m]))", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "ops", "noValue": "0" } },
      "links": [{ "title": "OTEL Collector", "url": "/d/ct-otel-collector/opentelemetry-collector" }]
    },
    {
      "title": "OTEL Failures",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "sum(rate(otelcol_exporter_send_failed_spans[5m]))", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 21, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "ops", "noValue": "0", "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 1, "color": "red" }] } } }
    },

    {
      "title": "Database & Messaging",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "collapsed": false
    },
    {
      "title": "PG Connections",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "sum(pg_stat_activity_count)", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 0, "y": 5 }
    },
    {
      "title": "PG TPS",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "sum(rate(pg_stat_database_xact_commit[1m]))", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 3, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "PG Cache Hit %",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "(sum(rate(pg_stat_database_blks_hit[5m])) / (sum(rate(pg_stat_database_blks_hit[5m])) + sum(rate(pg_stat_database_blks_read[5m])))) * 100", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 6, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "value": 0, "color": "red" }, { "value": 80, "color": "yellow" }, { "value": 95, "color": "green" }] } } }
    },
    {
      "title": "NATS Msgs/s",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "rate(gnatsd_varz_in_msgs[1m]) + rate(gnatsd_varz_out_msgs[1m])", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 9, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "JetStream Streams",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "jetstream_server_total_streams", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 12, "y": 5 }
    },
    {
      "title": "JS Consumers",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "jetstream_server_total_consumers", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 15, "y": 5 }
    },
    {
      "title": "S3 Req/s",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "sum(rate(minio_s3_requests_total[1m]))", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 18, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "S3 Storage Used",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "minio_cluster_usage_total_bytes", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 21, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },

    {
      "title": "Telephony (JTAPI)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "collapsed": false
    },
    {
      "title": "CTI Ports In Use",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "jtapi_cti_ports_in_use", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 0, "y": 9 }
    },
    {
      "title": "CTI Ports Idle",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "jtapi_cti_ports_idle", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 3, "y": 9 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } }
    },
    {
      "title": "CTI Ports Error",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "jtapi_cti_ports_error", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 6, "y": 9 },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 1, "color": "red" }] } } }
    },
    {
      "title": "Active Streams",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "jtapi_streams_active", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 9, "y": 9 }
    },
    {
      "title": "Calls Monitored",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "jtapi_calls_monitored_total", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 12, "y": 9 }
    },
    {
      "title": "Injections OK",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "rate(jtapi_injections_total{status=\"success\"}[5m])", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 15, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "fixed", "fixedColor": "green" } } }
    },
    {
      "title": "Injections Failed",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "rate(jtapi_injections_total{status=\"failed\"}[5m])", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 18, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "ops", "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 0.01, "color": "red" }] } } }
    },
    {
      "title": "Injection Success %",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "(rate(jtapi_injections_total{status=\"success\"}[5m]) / (rate(jtapi_injections_total{status=\"success\"}[5m]) + rate(jtapi_injections_total{status=\"failed\"}[5m]))) * 100", "legendFormat": "" }],
      "gridPos": { "h": 3, "w": 3, "x": 21, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "value": 0, "color": "red" }, { "value": 90, "color": "yellow" }, { "value": 99, "color": "green" }] } } }
    },

    {
      "title": "Traffic & Throughput",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "collapsed": false
    },
    {
      "title": "PostgreSQL Transactions",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "sum(rate(pg_stat_database_xact_commit[5m]))", "legendFormat": "commits" },
        { "expr": "sum(rate(pg_stat_database_xact_rollback[5m]))", "legendFormat": "rollbacks" }
      ],
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "NATS Messages",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(gnatsd_varz_in_msgs[1m])", "legendFormat": "in" },
        { "expr": "rate(gnatsd_varz_out_msgs[1m])", "legendFormat": "out" }
      ],
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Caddy Requests & Latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "sum(rate(caddy_http_requests_total[1m]))", "legendFormat": "req/s" },
        { "expr": "histogram_quantile(0.99, sum(rate(caddy_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P99 latency" }
      ],
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 13 },
      "fieldConfig": { "overrides": [{ "matcher": { "id": "byName", "options": "req/s" }, "properties": [{ "id": "unit", "value": "ops" }] }, { "matcher": { "id": "byName", "options": "P99 latency" }, "properties": [{ "id": "unit", "value": "s" }, { "id": "custom.axisPlacement", "value": "right" }] }] }
    },
    {
      "title": "JTAPI Calls & Injections",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(jtapi_calls_monitored_total[5m])", "legendFormat": "calls" },
        { "expr": "rate(jtapi_injections_total{status=\"success\"}[5m])", "legendFormat": "injections ok" },
        { "expr": "rate(jtapi_injections_total{status=\"failed\"}[5m])", "legendFormat": "injections fail" }
      ],
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [{ "matcher": { "id": "byName", "options": "injections fail" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }] }
    },
    {
      "title": "S3 Operations",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "rate(minio_s3_requests_total[5m])", "legendFormat": "{{ api }}" }],
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "S3 Bandwidth",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(minio_s3_traffic_sent_bytes[1m])", "legendFormat": "sent" },
        { "expr": "rate(minio_s3_traffic_received_bytes[1m])", "legendFormat": "received" }
      ],
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "title": "OTEL Pipeline",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "sum(rate(otelcol_receiver_accepted_spans[1m]))", "legendFormat": "received" },
        { "expr": "sum(rate(otelcol_exporter_sent_spans[1m]))", "legendFormat": "exported" },
        { "expr": "sum(rate(otelcol_exporter_send_failed_spans[1m]))", "legendFormat": "failed" }
      ],
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [{ "matcher": { "id": "byName", "options": "failed" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }] }
    },
    {
      "title": "CTI Port Pool",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "jtapi_cti_port_pool_size", "legendFormat": "pool size" },
        { "expr": "jtapi_cti_ports_in_use", "legendFormat": "in use" },
        { "expr": "jtapi_cti_ports_error", "legendFormat": "error" }
      ],
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 20 },
      "fieldConfig": { "overrides": [{ "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }, { "matcher": { "id": "byName", "options": "pool size" }, "properties": [{ "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }] }] }
    }
  ],
  "schemaVersion": 39,
  "tags": ["overview"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "CallTelemetry Overview",
  "uid": "ct-overview"
}
