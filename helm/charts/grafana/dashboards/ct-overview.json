      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (status) (rate(cdrcisco_prom_ex_phoenix_http_request_duration_milliseconds_count[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
