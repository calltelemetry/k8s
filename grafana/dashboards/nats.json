{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "Current Connections",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "gnatsd_varz_current_connections", "legendFormat": "connections" }],
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 }
    },
    {
      "title": "Total Connections",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "gnatsd_varz_total_connections", "legendFormat": "total" }],
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 }
    },
    {
      "title": "JetStream Streams",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "jetstream_server_total_streams", "legendFormat": "streams" }],
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 }
    },
    {
      "title": "JetStream Consumers",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "jetstream_server_total_consumers", "legendFormat": "consumers" }],
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 }
    },
    {
      "title": "Connection Saturation",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "gnatsd_varz_current_connections / gnatsd_varz_max_connections * 100", "legendFormat": "usage %" }],
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 70, "color": "yellow" }, { "value": 90, "color": "red" }] } } }
    },
    {
      "title": "Messages/s In",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "rate(gnatsd_varz_in_msgs[1m])", "legendFormat": "in" }],
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Messages In / Out",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(gnatsd_varz_in_msgs[1m])", "legendFormat": "in" },
        { "expr": "rate(gnatsd_varz_out_msgs[1m])", "legendFormat": "out" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Bytes In / Out",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(gnatsd_varz_in_bytes[1m])", "legendFormat": "in" },
        { "expr": "rate(gnatsd_varz_out_bytes[1m])", "legendFormat": "out" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "title": "JetStream Stream Sequences",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "jetstream_stream_last_seq", "legendFormat": "{{ stream }}" }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }
    },
    {
      "title": "JetStream Consumer Pending",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "jetstream_consumer_num_pending", "legendFormat": "{{ stream }}/{{ consumer }} pending" },
        { "expr": "jetstream_consumer_num_ack_pending", "legendFormat": "{{ stream }}/{{ consumer }} ack pending" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 }
    },
    {
      "title": "Subscriptions",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "gnatsd_varz_subscriptions", "legendFormat": "subscriptions" }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 }
    },
    {
      "title": "Slow Consumers",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "gnatsd_varz_slow_consumers", "legendFormat": "slow consumers" }],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 1, "color": "red" }] } } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["nats", "messaging"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "NATS + JetStream",
  "uid": "ct-nats"
}
