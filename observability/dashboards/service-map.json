  "panels": [
    {
      "title": "Service Map",
      "type": "nodeGraph",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "targets": [
        {
          "query": "{}",
          "queryType": "serviceMap",
          "refId": "A",
          "serviceMapQuery": "{resource.service.name=~\"cisco-cdr|jtapi-sidecar|ct-media|nats\"}"
        }
      ]
    },
    {
      "title": "Service Error Rates",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(traces_service_graph_request_failed_total[5m])) by (client, server) / sum(rate(traces_service_graph_request_total[5m])) by (client, server)",
          "legendFormat": "{{client}} -> {{server}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Service Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(traces_service_graph_request_total[5m])) by (client, server)",
          "legendFormat": "{{client}} -> {{server}}",
          "refId": "A"
        }
      ]
    }
  ],
